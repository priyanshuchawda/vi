# Copy to `.env.aws.prod` before the first real prod rollout and replace all
# placeholder names with dedicated prod resources. Do not reuse the dev bucket
# or dev DynamoDB tables for production.
#
# Usage:
# AWS_ENV_FILE=.env.aws.prod npm run aws:check:account
# AWS_ENV_FILE=.env.aws.prod npm run aws:deploy:cloud-backend

AWS_REGION=eu-central-1

# Backend stack identity
AWS_CLOUDBACKEND_PROJECT_NAME=quickcut
AWS_CLOUDBACKEND_ENVIRONMENT=prod
AWS_CLOUDBACKEND_STACK_NAME=quickcut-cloud-backend-prod

# Optional explicit audit targets
AWS_CLOUDBACKEND_DEV_ENVIRONMENT=dev
AWS_CLOUDBACKEND_DEV_STACK_NAME=quickcut-cloud-backend-dev
AWS_CLOUDBACKEND_PROD_ENVIRONMENT=prod
AWS_CLOUDBACKEND_PROD_STACK_NAME=quickcut-cloud-backend-prod

# Dedicated prod resource names
AWS_CLOUDBACKEND_ARTIFACT_BUCKET=quickcut-<account-id>-artifacts-prod
AWS_S3_BUCKET=quickcut-<account-id>-storage-prod
AWS_DYNAMODB_PROFILES_TABLE=quickcut-user-profiles-prod
AWS_DYNAMODB_ANALYSIS_TABLE=quickcut-channel-analysis-prod
AWS_DYNAMODB_USER_LINKS_TABLE=quickcut-user-links-prod
AWS_DYNAMODB_INSTALLATIONS_TABLE=quickcut-client-installations-prod

# Landing website
AWS_LANDING_BUCKET=quickcut-landing-<account-id>-prod
AWS_LANDING_S3_PREFIX=

# Linux release hosting
AWS_RELEASE_BUCKET=quickcut-landing-<account-id>-prod
AWS_RELEASE_S3_PREFIX=releases
AWS_RUNTIME_LINUX_RELEASE_BASE_URL=

# App/backend runtime
AWS_BACKEND_MODE=apigw
AWS_BACKEND_URL=https://<prod-api-id>.execute-api.eu-central-1.amazonaws.com
AWS_BACKEND_AUTH_TOKEN=
AWS_RUNTIME_BACKEND_MODE=apigw
AWS_RUNTIME_BACKEND_URL=https://<prod-api-id>.execute-api.eu-central-1.amazonaws.com
AWS_RUNTIME_BACKEND_AUTH_TOKEN=

# Low-cost backend defaults
AWS_CLOUDBACKEND_API_ACCESS_LOG_RETENTION_DAYS=14
AWS_CLOUDBACKEND_LAMBDA_LOG_RETENTION_DAYS=14
AWS_CLOUDBACKEND_LAMBDA_ERROR_ALARM_THRESHOLD=1
AWS_CLOUDBACKEND_LAMBDA_THROTTLE_ALARM_THRESHOLD=1
AWS_CLOUDBACKEND_API_5XX_ALARM_THRESHOLD=1
