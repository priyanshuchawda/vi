# YouTube Data API v3 Key
# Get yours at: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# Optional YouTube OAuth client config for upload/authentication
# Prefer the env-based contract below for packaged/production builds.
# Legacy fallback is a local Google OAuth JSON file pointed to by
# YOUTUBE_OAUTH_CREDENTIALS_PATH.
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=
YOUTUBE_OAUTH_REDIRECT_URI=
YOUTUBE_OAUTH_CREDENTIALS_PATH=

# AWS Bedrock Credentials
# Get yours at: https://console.aws.amazon.com/iam/
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_SESSION_TOKEN=your_aws_session_token_here_if_using_temporary_credentials
AWS_REGION=eu-central-1
AWS_S3_BUCKET=your_s3_bucket_here
AWS_LANDING_BUCKET=your_landing_bucket_here
AWS_LANDING_S3_PREFIX=
AWS_BACKEND_MODE=direct
AWS_BACKEND_URL=
AWS_BACKEND_AUTH_TOKEN=
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL_ID=gemini-2.5-flash-lite

# Frontend model hint (non-secret)
VITE_BEDROCK_MODEL_ID=amazon.nova-lite-v1:0

# Observability / Error tracking (optional; disabled by default)
ENABLE_ERROR_TRACKING=0
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
LOG_LEVEL=info

VITE_ENABLE_ERROR_TRACKING=0
VITE_SENTRY_DSN=
VITE_LOG_LEVEL=info
