+    // Only create cache if content is large enough
+    if (!actualTokens || actualTokens < MIN_TOKENS_FOR_CACHE) {
+      console.log(`️ Content too small for caching (${actualTokens} tokens, min ${MIN_TOKENS_FOR_CACHE})`);
+      return null;
+    }
