flowchart TB
    subgraph ROW1[" "]
        direction LR
        CREATOR(["Creator<br/>Natural Language<br/>Edit · Enhance · Analyze"])
        --> CHAT["AI Chat Interface<br/>Intent Classifier · Normalizer<br/>Agent Router (single_pass · agentic)<br/>Conversation Lane · Request Queue"]
        --> BEDROCK["Amazon Bedrock<br/>Nova Lite v1 · Converse API<br/>Autonomous Plan→Act→Verify<br/>Tool Use (1 per step)"]
        --> BACKEND["Cloud Backend Adapter<br/>direct mode (AWS SDK)<br/>apigw mode (HTTP + JWT)<br/>Zod-Validated REST Routes"]
    end

    subgraph ROW2[" "]
        direction LR
        YTAPI["YouTube Data API v3<br/>Channel Metadata<br/>Top Videos · Recent Videos<br/>OAuth Upload"]
        --> ANALYSIS["Channel Analysis Engine<br/>Content Strengths · Weaknesses<br/>Growth Suggestions<br/>Editing Recommendations"]
        TOOLS["Tool Orchestration<br/>40+ Tools · Validation · Recovery<br/>Cut · Trim · Merge · Effects<br/>Captions · Script · Story Beats"]
        --> LOCAL["Local Desktop Processing<br/>FFmpeg Export Pipeline<br/>Vosk Speech Transcription<br/>Timeline Engine · Zustand State"]
    end

    subgraph ROW3[" "]
        direction LR
        DDB["Amazon DynamoDB<br/>user-profiles (permanent)<br/>channel-analysis (TTL 7d)<br/>user-links (TTL 30d)<br/>PAY_PER_REQUEST"]
        --> CACHE["3-Tier Cache<br/>L1: In-Memory Map<br/>L2: Local Disk JSON<br/>L3: DynamoDB Fallback"]
        S3["Amazon S3<br/>videos/ — Multipart Export<br/>ai-context/ — Snapshots (gzip)<br/>memory/ — Clip Analysis (gzip)<br/>Lifecycle: STANDARD→IA→Expire"]
        --> CONTEXT["Context Engine<br/>YouTube Analysis · Timeline State<br/>Clip Scene Memory · Story Scores<br/>Creator Preferences · Token Budget"]
    end

    BEDROCK -->|"JSON Tool Calls"| TOOLS
    BEDROCK -->|"Analysis Prompt"| ANALYSIS
    TOOLS -->|"Verify + Continue"| BEDROCK
    ANALYSIS -->|"Cache Results"| DDB
    LOCAL -->|"Export Upload"| S3
    CACHE -->|"Cached Data"| CHAT
    CONTEXT -->|"Enriched Context"| BEDROCK
    BACKEND --> DDB
    BACKEND --> S3

