{
  "name": "quickcut",
  "private": true,
  "version": "1.1.0",
  "description": "A fast, lightweight desktop video editor for quick cuts, trims, and exports.",
  "author": "QuickCut Team",
  "homepage": "https://github.com/priyanshuchawda/vi",
  "license": "MIT",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:react\" \"npm run dev:electron\"",
    "dev:react": "vite",
    "build:runtime-config": "node scripts/build/generate-runtime-config.mjs",
    "build:electron": "tsc -p tsconfig.electron.json && node scripts/build/build-electron-preload.mjs",
    "dist:check:assets": "node scripts/build/check-release-assets.mjs",
    "mermaid:render": "node scripts/mermaid/render.mjs",
    "dev:electron": "npm run build:electron && concurrently -k \"tsc -p tsconfig.electron.json -w\" \"node scripts/build/build-electron-preload.mjs --watch\" \"wait-on http-get://localhost:7377 && node scripts/dev/run-electron.mjs\"",
    "build": "npm run build:runtime-config && tsc -b && npm run build:electron && vite build",
    "dist": "npm run build && npm run dist:check:assets -- linux && electron-builder --publish never",
    "dist:all": "npm run build && npm run dist:check:assets -- mac win linux && electron-builder --mac --arm64 --x64 --publish never && electron-builder --win nsis --x64 --publish never && electron-builder --linux AppImage deb --x64 --publish never",
    "dist:mac": "npm run build && npm run dist:check:assets -- mac && electron-builder --mac --arm64 --x64 --publish never",
    "dist:win": "npm run build && npm run dist:check:assets -- win && electron-builder --win nsis --x64 --publish never",
    "dist:linux": "npm run build && npm run dist:check:assets -- linux && electron-builder --linux AppImage deb --x64 --publish never",
    "dist:linux:appimage": "npm run build && npm run dist:check:assets -- linux && electron-builder --linux AppImage --x64 --publish never",
    "dist:linux:deb": "npm run build && npm run dist:check:assets -- linux && electron-builder --linux deb --x64 --publish never",
    "dist:publish": "npm run build && electron-builder --publish always",
    "test": "vitest run",
    "test:e2e:smoke": "playwright test test/e2e/smoke.spec.ts",
    "architecture:check": "depcruise --config .dependency-cruiser.cjs \"src/**/*.{ts,tsx}\" \"electron/**/*.ts\"",
    "lint:guard:no-explicit-any-file-disable": "node scripts/hygiene/check-no-explicit-any-file-disable.mjs",
    "hygiene": "npm run lint:guard:no-explicit-any-file-disable && npm run architecture:check",
    "thirdparty:generate": "node scripts/compliance/generate-third-party-notices.mjs",
    "thirdparty:check": "npm run thirdparty:generate && git diff --exit-code ThirdPartyNotices.json",
    "typecheck": "tsc -b --pretty false && tsc -p tsconfig.electron.json --pretty false --noEmit && tsc -p tsconfig.test.json --pretty false --noEmit",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:memory": "vitest run test/integration/ai-memory.test.ts",
    "typecheck:backend": "tsc -p tsconfig.backend.json --pretty false --noEmit",
    "aws:build:cloud-backend": "node scripts/aws/build-cloud-backend.mjs",
    "aws:check:account": "node scripts/aws/check-account.mjs",
    "aws:deploy:cloud-backend": "node scripts/aws/deploy-cloud-backend.mjs",
    "aws:delete:cloud-backend": "node scripts/aws/delete-cloud-backend.mjs",
    "aws:deploy:landing": "node scripts/aws/deploy-landing.mjs",
    "aws:deploy:landing:dryrun": "node scripts/aws/deploy-landing.mjs --dryrun",
    "aws:verify:baseline": "node scripts/aws/verify-baseline.mjs",
    "eval:ai:one": "node scripts/ai-eval/run-bedrock-eval.mjs",
    "eval:ai:batch": "node scripts/ai-eval/run-bedrock-batch.mjs",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "pre-commit": "lint-staged",
    "prepare": "husky",
    "preview": "vite preview"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.997.0",
    "@aws-sdk/client-dynamodb": "^3.1004.0",
    "@aws-sdk/client-s3": "^3.1004.0",
    "@aws-sdk/lib-dynamodb": "^3.1004.0",
    "@aws-sdk/lib-storage": "^3.1004.0",
    "@aws-sdk/s3-request-presigner": "^3.1004.0",
    "@google/genai": "^1.44.0",
    "@sentry/browser": "^10.11.0",
    "@sentry/node": "^10.11.0",
    "@tanstack/react-query": "^5.90.2",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.4",
    "electron-updater": "^6.7.0",
    "fluent-ffmpeg": "^2.1.3",
    "googleapis": "^171.4.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.4.0",
    "uuid": "^13.0.0",
    "vosk-koffi": "^1.1.1",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.1",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.2.1",
    "dependency-cruiser": "^16.10.4",
    "electron": "^40.0.0",
    "electron-builder": "^26.4.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "happy-dom": "^20.8.3",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "lint-staged": "^16.2.2",
    "postcss": "^8.5.8",
    "prettier": "^3.6.2",
    "puppeteer": "^23.11.1",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix --no-warn-ignored"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  },
  "build": {
    "appId": "com.quickcut.app",
    "productName": "QuickCut",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "asar": true,
    "asarUnpack": [
      "**/*.node",
      "node_modules/koffi/**/*",
      "node_modules/vosk-koffi/**/*"
    ],
    "directories": {
      "output": "D:/vi-release"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "deb": {
      "priority": "optional",
      "packageCategory": "video",
      "maintainer": "QuickCut Team"
    },
    "files": [
      "dist-electron/**/*",
      "dist/**/*"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "priyanshuchawda",
        "repo": "vi",
        "releaseType": "draft"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/logo.png",
      "extraResources": [
        {
          "from": "resources/ffmpeg-win",
          "to": "resources/ffmpeg-win",
          "filter": [
            "**/*"
          ]
        },
        {
          "from": "resources/README.md",
          "to": "resources/README.md"
        },
        {
          "from": "resources/generated/runtime-config.json",
          "to": "runtime/runtime-config.json"
        }
      ]
    },
    "mac": {
      "target": "dmg",
      "icon": "public/logo.png",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "extraResources": [
        {
          "from": "resources/ffmpeg-mac",
          "to": "resources/ffmpeg-mac",
          "filter": [
            "**/*"
          ]
        },
        {
          "from": "resources/README.md",
          "to": "resources/README.md"
        },
        {
          "from": "resources/generated/runtime-config.json",
          "to": "runtime/runtime-config.json"
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/logo.png",
      "category": "Video",
      "executableName": "quickcut",
      "extraResources": [
        {
          "from": "resources/ffmpeg-linux",
          "to": "resources/ffmpeg-linux",
          "filter": [
            "**/*"
          ]
        },
        {
          "from": "resources/README.md",
          "to": "resources/README.md"
        },
        {
          "from": "resources/generated/runtime-config.json",
          "to": "runtime/runtime-config.json"
        }
      ]
    }
  }
}
