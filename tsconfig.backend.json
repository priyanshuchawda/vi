{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ESNext",
    "outDir": "dist-backend",
    "strict": true,
    "noImplicitReturns": true,
    "noImplicitOverride": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"]
  },
  "include": [
    "backend/**/*",
    "electron/services/cloudBackendApi.ts",
    "electron/services/awsStorageService.ts",
    "electron/utils/logger.ts"
  ]
}
